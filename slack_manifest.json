{
  "display_information": {
    "name": "Marketinko",
    "description": "AI asistent za Eagle Events oglase",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "Marketinko",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "im:history",
        "im:read",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}
